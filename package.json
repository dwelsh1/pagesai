{
  "name": "notion-clone-e2e-starter",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "install:playwright": "npx playwright install --with-deps",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "PWDEBUG=1 playwright test",
    "test:headed": "playwright test --headed",
    "test:ci": "playwright test --reporter=line,html --workers=2",
    "test:a11y": "playwright test tests/accessibility",
    "test:api": "playwright test tests/api",
    "show-report": "playwright show-report",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "codegen": "playwright codegen $BASE_URL",
    "test:update-snapshots": "PLAYWRIGHT_UPDATE_SNAPSHOTS=1 playwright test",
    "lighthouse": "lhci autorun --config=./scripts/lighthouse/lhci.config.js",
    "lighthouse:ci": "lhci autorun --config=./scripts/lighthouse/lhci.config.js --collect.url=${LHCI_URL:-http://localhost:3000}",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "seed": "tsx scripts/seed.ts",
    "fts:setup": "tsx scripts/run-sql.ts prisma/fts.sql",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.5.0",
    "@types/testing-library__jest-dom": "^6.0.0",
    "allure-playwright": "^3.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.11.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^48.2.4",
    "eslint-plugin-unused-imports": "^4.0.0",
    "jsdom": "^24.1.0",
    "lighthouse": "^12.2.0",
    "msw": "^2.4.10",
    "postcss": "^8.4.41",
    "prettier": "^3.3.3",
    "prisma": "^6.16.2",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.13",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.0.5"
  },
  "dependencies": {
    "@blocknote/mantine": "^0.41.1",
    "@blocknote/react": "^0.41.1",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@prisma/client": "^6.16.2",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@tanstack/react-query": "^5.90.5",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.4.1",
    "jose": "^6.1.0",
    "next": "^15.5.6",
    "next-themes": "^0.4.3",
    "rate-limiter-flexible": "^8.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  }
}
